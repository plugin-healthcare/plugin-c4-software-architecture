	pages = {11},
	file = {PDF:/Users/dkapitan/Zotero/storage/KQYILQDC/Leiner et al. - 2021 - Bringing AI to the clinic blueprint for a vendor-neutral AI deployment infrastructure.pdf:application/pdf},
}

