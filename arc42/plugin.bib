@misc{elliot2018future,
	title = {The future of statistical disclosure control},
	url = {http://arxiv.org/abs/1812.09204},
	doi = {10.48550/arXiv.1812.09204},
	abstract = {Statistical disclosure control (SDC) was not created in a single seminal paper nor following the invention of a new mathematical technique, rather it developed slowly in response to the practical challenges faced by data practitioners based at national statistical institutes (NSIs). SDC's subsequent emergence as a specialised academic field was an outcome of three interrelated socio-technical changes: (i) the advent of accessible computing as a research tool in the 1980s meant that it became possible - and then increasingly easy - for researchers to process larger quantities of data automatically; this naturally increased demand for such data; (ii) it became possible for data holders to process and disseminate detailed data as digital files and (iii) the number of organisations holding data about individuals proliferated. This also meant the number of potential adversaries with the resources to attack any given dataset increased exponentially. In this article, we describe the state of the art for SDC and then discuss the core issues and future challenges. In particular, we touch on SDC and big data, on SDC and machine learning, and on SDC and anti-discrimination.},
	urldate = {2026-01-27},
	publisher = {arXiv},
	author = {Elliot, Mark and Domingo-Ferrer, Josep},
	month = dec,
	year = {2018},
	note = {arXiv:1812.09204 [cs]},
	keywords = {Computer Science - Cryptography and Security},
	annote = {Comment: A contributing article to the National Statistician's Quality Review into Privacy and Data Confidentiality Methods},
	file = {Preprint PDF:/Users/dkapitan/Zotero/storage/GYVU5XE6/Elliot and Domingo-Ferrer - 2018 - The future of statistical disclosure control.pdf:application/pdf;Snapshot:/Users/dkapitan/Zotero/storage/EA4HXCYD/1812.html:text/html},
}

@inproceedings{vogt2017icarus,
	title = {Icarus: {Towards} a multistore database system},
	shorttitle = {Icarus},
	url = {https://ieeexplore.ieee.org/document/8258207},
	doi = {10.1109/BigData.2017.8258207},
	abstract = {The last years have seen a vast diversification on the database market. In contrast to the “one-size-fits-all” paradigm according to which systems have been designed in the past, today's database management systems (DBMS) are tuned for particular workloads. This has led to DBMSs optimized for high performance, high throughput read/write workloads in online transaction processing (OLTP) and systems optimized for complex analytical queries (OLAP). However, this approach reaches a limit when systems have to deal with mixed workloads that are neither pure OLAP nor pure OLTP workloads. In such cases, multistores are increasingly gaining popularity. Rather than supporting one single database paradigm and addressing one particular workload, multistores encompass several DBMSs that store data in different schemas and allow to route requests on a per-query level to the most appropriate system. In this paper, we introduce the multistore ICARUS. In our evaluation based on a workload that combines OLTP and OLAP elements, we show that ICARUS is able to speed-up queries up to a factor of three by properly routing queries to the best underlying DBMS.},
	urldate = {2026-01-27},
	booktitle = {2017 {IEEE} {International} {Conference} on {Big} {Data} ({Big} {Data})},
	author = {Vogt, Marco and Stiemer, Alexander and Schuldt, Heiko},
	month = dec,
	year = {2017},
	keywords = {Optimization, Query processing, Routing, mixed OLTP and OLAP workload, Multistore databases, query routing, Structured Query Language, Throughput},
	pages = {2490--2499},
	file = {Snapshot:/Users/dkapitan/Zotero/storage/TVWPML2W/8258207.html:text/html},
}

