	file = {Full Text PDF:/Users/dkapitan/Zotero/storage/E3WEF54V/Hoxhaj et al. - 2025 - INSIGHT A Tool for Fit-for-Purpose Evaluation and Quality Assessment of Standardized Observational.pdf:application/pdf;Snapshot:/Users/dkapitan/Zotero/storage/6EB3SJVZ/pds.html:text/html},
}

