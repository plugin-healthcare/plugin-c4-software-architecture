	keywords = {Humans, Reproducibility of Results, Patients, Electronic Health Records, Health Level Seven, Information Dissemination, electronic health records, interoperability, HL7 FHIR, Information Storage and Retrieval, Datasets as Topic, fast healthcare interoperability resources, MIMIC-IV, open data},
