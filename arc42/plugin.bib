@article{gouthamchand2024making,
	title = {Making head and neck cancer clinical data {Findable}-{Accessible}-{Interoperable}-{Reusable} to support multi-institutional collaboration and federated learning},
	volume = {1},
	issn = {2976-8705},
	url = {https://doi.org/10.1093/bjrai/ubae005},
	doi = {10.1093/bjrai/ubae005},
	abstract = {Federated learning (FL) is a group of methodologies where statistical modelling can be performed without exchanging identifiable patient data between cooperating institutions. To realize its potential for AI development on clinical data, a number of bottlenecks need to be addressed. One of these is making data Findable-Accessible-Interoperable-Reusable (FAIR). The primary aim of this work is to show that tools making data FAIR allow consortia to collaborate on privacy-aware data exploration, data visualization, and training of models on each other’s original data.We propose a “Schema-on-Read” FAIR-ification method that adapts for different (re)analyses without needing to change the underlying original data. The procedure involves (1) decoupling the contents of the data from its schema and database structure, (2) annotation with semantic ontologies as a metadata layer, and (3) readout using semantic queries. Open-source tools are given as Docker containers to help local investigators prepare their data on-premises.We created a federated privacy-preserving visualization dashboard for case mix exploration of 5 distributed datasets with no common schema at the point of origin. We demonstrated robust and flexible prognostication model development and validation, linking together different data sources—clinical risk factors and radiomics.Our procedure leads to successful (re)use of data in FL-based consortia without the need to impose a common schema at every point of origin of data.This work supports the adoption of FL within the healthcare AI community by sharing means to make data more FAIR.},
	number = {1},
	urldate = {2025-09-15},
	journal = {BJR{\textbar}Artificial Intelligence},
	author = {Gouthamchand, Varsha and Choudhury, Ananya and Hoebers, Frank J P and Wesseling, Frederik W R and Welch, Mattea and Kim, Sejin and Kazmierska, Joanna and Dekker, Andre and Haibe-Kains, Benjamin and van Soest, Johan and Wee, Leonard},
	month = mar,
	year = {2024},
	pages = {ubae005},
	file = {Full Text PDF:/Users/dkapitan/Zotero/storage/LR6B9UBN/Gouthamchand et al. - 2024 - Making head and neck cancer clinical data Findable-Accessible-Interoperable-Reusable to support mult.pdf:application/pdf;Snapshot:/Users/dkapitan/Zotero/storage/IJZDIRFR/ubae005.html:text/html},
}

@article{sadoughi2025breaking,
	series = {Advances in {Database} {Technology} - {EDBT}},
	title = {Breaking {Down} the {Data}-{Metadata} {Barrier} for {Effective} {Property} {Graph} {Data} {Management}: 28th {International} {Conference} on {Extending} {Database} {Technology}, {EDBT} 2025},
	shorttitle = {Breaking {Down} the {Data}-{Metadata} {Barrier} for {Effective} {Property} {Graph} {Data} {Management}},
	url = {https://www.scopus.com/pages/publications/105007897768},
	doi = {10.48786/edbt.2025.80},
	abstract = {The ISO standard Property Graph model has become increasingly popular for representing complex, interconnected data. However,
it lacks native support for querying metadata and reification, which limits its abilities to deal with the demands of modern
applications. We introduce the vision of Meta-Property Graph, a backwards compatible extension of the property graph model addressing these limitations. Our approach enables first-class treatment of labels and properties as queryable objects and supports
reification of substructures in a graph. We propose MetaGPML, a backwards compatible extension of the Graph Pattern Matching
Language forming the core of the ISO standard GQL, to query these enhanced graphs. We demonstrate how these foundations
pave the way for advanced data analytics and governance tasks that are challenging or impossible with current property graph
systems.},
	urldate = {2025-09-16},
	journal = {Proceedings 28th International Conference on Extending Database Technology ( EDBT 2025 ) Barcelona, Spain, March 25 - March 28},
	publisher = {OpenProceedings.org},
	author = {Sadoughi, Sepehr and Yakovets, Nikolay and Fletcher, George H.L.},
	month = mar,
	year = {2025},
	keywords = {Graph data management, Graph data models, Knowledge graphs, Property graphs},
	pages = {978--984},
}

